# Local release helper setup:
# 1. Copy this file to .env.
# 2. Find your EDMC plugins directory in EDMC by opening File -> Settings,
#    then the Plugins tab, then clicking Open Plugins Directory.
# 3. Choose a backup archives directory on this device. tools/local-release
#    creates a timestamped directory there and stores a full backup of the
#    currently installed MarketScout plugin before copying over new files.
#    This helps avoid overwriting a working plugin with a work-in-progress
#    version that might have a bug.

# Absolute path to EDMC's plugins directory.
EDMC_PLUGINS_DIR=

# Absolute path where tools/local-release should write timestamped backups.
PLUGIN_BACKUP_ARCHIVES_DIR=
